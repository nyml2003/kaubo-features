{
  "var": {
    "prefix": "var",
    "body": ["var ${1:name} = ${2:value};"],
    "description": "Variable declaration"
  },
  "const": {
    "prefix": "const",
    "body": ["const ${1:name} = ${2:value};"],
    "description": "Constant declaration"
  },
  "if": {
    "prefix": "if",
    "body": ["if ${1:condition} {", "\t${2:body}", "}"],
    "description": "If statement"
  },
  "if_else": {
    "prefix": "ife",
    "body": ["if ${1:condition} {", "\t${2:body}", "} else {", "\t${3:body}", "}"],
    "description": "If-else statement"
  },
  "if_elif": {
    "prefix": "ifel",
    "body": ["if ${1:condition} {", "\t${2:body}", "} else if ${3:condition} {", "\t${4:body}", "} else {", "\t${5:body}", "}"],
    "description": "If-else if-else statement"
  },
  "while": {
    "prefix": "while",
    "body": ["while ${1:condition} {", "\t${2:body}", "}"],
    "description": "While loop"
  },
  "for_in": {
    "prefix": "for",
    "body": ["for ${1:item} in ${2:collection} {", "\t${3:body}", "}"],
    "description": "For-in loop"
  },
  "lambda": {
    "prefix": "fn",
    "body": ["|${1:params}| {", "\t${2:body}", "}"],
    "description": "Lambda expression"
  },
  "struct": {
    "prefix": "struct",
    "body": ["struct ${1:Name} {", "\t${2:field}: ${3:Type},", "}"],
    "description": "Struct definition"
  },
  "impl": {
    "prefix": "impl",
    "body": ["impl ${1:Name} {", "\t${2:method}: |${3:self}, ${4:params}| {", "\t\t${5:body}", "\t},", "}"],
    "description": "Impl block"
  },
  "fun_call": {
    "prefix": "call",
    "body": ["${1:function}(${2:args});"],
    "description": "Function call"
  },
  "return": {
    "prefix": "ret",
    "body": ["return ${1:value};"],
    "description": "Return statement"
  },
  "import": {
    "prefix": "import",
    "body": ["import \"${1:module}\";"],
    "description": "Import module"
  },
  "import_as": {
    "prefix": "importa",
    "body": ["import \"${1:module}\" as ${2:alias};"],
    "description": "Import module with alias"
  },
  "from_import": {
    "prefix": "from",
    "body": ["from \"${1:module}\" import { ${2:exports} };"],
    "description": "From-import statement"
  },
  "export": {
    "prefix": "export",
    "body": ["export ${1:const} ${2:name} = ${3:value};"],
    "description": "Export declaration"
  },
  "async_fn": {
    "prefix": "async",
    "body": ["async |${1:params}| {", "\t${2:body}", "}"],
    "description": "Async expression"
  },
  "await_expr": {
    "prefix": "await",
    "body": ["await ${1:expr};"],
    "description": "Await expression"
  },
  "print_string": {
    "prefix": "print",
    "body": ["print(\"${1:value}\");"],
    "description": "Print string"
  },
  "print_expr": {
    "prefix": "prints",
    "body": ["print(${1:expr}.to_string());"],
    "description": "Print expression value"
  }
}
