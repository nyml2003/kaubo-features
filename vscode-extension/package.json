{
  "name": "kaubo",
  "displayName": "Kaubo Language Support",
  "description": "Syntax highlighting, snippets, and diagnostics for the Kaubo programming language",
  "version": "0.1.0",
  "publisher": "kaubo-lang",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:kaubo"
  ],
  "contributes": {
    "languages": [
      {
        "id": "kaubo",
        "aliases": ["Kaubo", "kaubo"],
        "extensions": [".kb"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kaubo",
        "scopeName": "source.kaubo",
        "path": "./syntaxes/kaubo.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "kaubo",
        "path": "./snippets/kaubo.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
