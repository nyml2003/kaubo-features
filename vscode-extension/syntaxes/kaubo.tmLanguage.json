{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Kaubo",
  "scopeName": "source.kaubo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#template-strings" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#atoms" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.kaubo",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.kaubo",
          "match": "//.*$"
        }
      ]
    },
    "template-strings": {
      "patterns": [
        {
          "name": "string.template.kaubo",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.kaubo",
              "match": "\\{\\{|\\}\\}"
            },
            {
              "name": "meta.embedded.expression.kaubo",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "#keywords" },
                { "include": "#atoms" },
                { "include": "#numbers" },
                { "include": "#operators" },
                { "include": "#identifiers" }
              ]
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.kaubo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.kaubo",
              "match": "\\\\(n|r|t|\\\\|\"|0)"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.kaubo",
          "match": "\\b(if|else|while|for|in|break|continue|return|match)\\b"
        },
        {
          "name": "keyword.declaration.kaubo",
          "match": "\\b(const|var)\\b"
        },
        {
          "name": "keyword.type.kaubo",
          "match": "\\b(struct|enum|interface|impl)\\b"
        },
        {
          "name": "keyword.other.kaubo",
          "match": "\\b(export|import|from|as|operator|async|await|and|or|not|self)\\b"
        }
      ]
    },
    "atoms": {
      "patterns": [
        {
          "name": "constant.language.boolean.kaubo",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.kaubo",
          "match": "\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.kaubo",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.kaubo",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.nullish.kaubo",
          "match": "\\?\\?|\\?\\.|\\?\\["
        },
        {
          "name": "keyword.operator.comparison.kaubo",
          "match": "==|!=|>=|<=|->|>>|\\|>"
        },
        {
          "name": "keyword.operator.arithmetic.kaubo",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.assignment.kaubo",
          "match": "="
        },
        {
          "name": "keyword.operator.comparison.kaubo",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.spread.kaubo",
          "match": "\\.\\.\\."
        },
        {
          "name": "punctuation.separator.kaubo",
          "match": "[,:;]"
        },
        {
          "name": "punctuation.section.kaubo",
          "match": "[(){}\\[\\]]"
        },
        {
          "name": "keyword.operator.accessor.kaubo",
          "match": "\\."
        },
        {
          "name": "keyword.operator.lambda.kaubo",
          "match": "\\|"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "entity.name.function.kaubo",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()"
        },
        {
          "name": "entity.name.type.kaubo",
          "match": "(?<=(struct|enum|interface|impl)\\s+)[a-zA-Z_][a-zA-Z0-9_]*"
        },
        {
          "name": "variable.other.kaubo",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
