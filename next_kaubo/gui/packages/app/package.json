{
  "name": "@kaubo/app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @kaubo/types build && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "@kaubo/wasm": "workspace:*",
    "@lezer/common": "^1.5.2",
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@kaubo/types": "workspace:*",
    "@types/node": "^22.0.0",
    "eslint": "^9.28.0",
    "eslint-plugin-solid": "^0.14.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.5.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.32.0",
    "vite": "^6.3.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.8"
  }
}
