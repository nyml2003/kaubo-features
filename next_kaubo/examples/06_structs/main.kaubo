// 06. Structs — 定义、实例化与字段访问

struct Point {
    x: int,
    y: int,
}

var p = Point { x: 100, y: 200 };

impl Point {
    distance: |self, other: Point| -> float {
        return std.sqrt((self.x - other.x) * (self.x - other.x) + (self.y - other.y) * (self.y - other.y));
    }
}

var p2 = Point { x: 300, y: 400 };
var d = p.distance(p2);
print(d);
